# 選擇資料庫：mysql 或 postgres
DB_TYPE=mysql

# 資料庫設定
DB_HOST=localhost
DB_PORT=3306
DB_NAME=linechatbot
DB_USER=chatbot_user
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_root_password

# LINE Bot 憑證（從 LINE Developers Console 取得）
LINE_CHANNEL_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# JWT 簽名金鑰（至少 256-bit，建議使用隨機產生）
# 產生方式：openssl rand -base64 64
JWT_SECRET=your_very_long_random_jwt_secret_at_least_256_bits_long_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AI 設定（也可在後台「AI 設定」頁修改，DB 為主、.env 為 fallback）
AI_PROVIDER=openai
OPENAI_API_KEY=

# 後台初始管理員（啟動時自動建立，見 V2__seed_data.sql）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
