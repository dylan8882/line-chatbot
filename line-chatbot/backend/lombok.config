# 讓 Lombok 自動把 @Qualifier 等 Spring 注入 annotation 從欄位複製到 @RequiredArgsConstructor 生成的 constructor 參數。
# 這樣寫：
#   @Qualifier("broadcastWorkerExecutor")
#   private final Executor workerExecutor;
# Lombok 就會生成：
#   public Manager(..., @Qualifier("broadcastWorkerExecutor") Executor workerExecutor) {...}
# 否則 Spring 在有多個同型別 bean 時會無法解析。

lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Value
